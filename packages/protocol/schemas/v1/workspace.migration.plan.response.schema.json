{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orchestra.protocol.v1.workspace.migration.plan.response",
  "title": "Orchestra Workspace Migration Plan Response",
  "type": "object",
  "required": ["from", "to", "result"],
  "properties": {
    "from": { "type": "string" },
    "to": { "type": "string" },
    "result": {
      "type": "object",
      "required": ["applied", "actions"],
      "properties": {
        "applied": { "type": "boolean" },
        "actions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "source", "target"],
            "properties": {
              "type": { "type": "string" },
              "source": { "type": "string" },
              "target": { "type": "string" },
              "note": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
